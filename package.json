{
  "name": "matrix",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev": "sh -c 'set -a; [ -f .env.local ] && . ./.env.local; set +a; exec pnpm -r --parallel dev'",
    "dev:mac": "wireit",
    "dev:ios": "wireit",
    "dev:all": "wireit",
    "open": "sh -c 'set -a; . ./.env.local; set +a; open \"http://localhost:${CLIENT_PORT:-5173}/?serverUrl=http://localhost:${MATRIX_PORT:-8080}&token=${MATRIX_TOKEN}&autoConnect=1\"'",
    "smoke:mac-automation": "bash scripts/smoke-mac-automation.sh",
    "test:release": "vitest run --config tests/release/vitest.config.ts",
    "test:release:real-agent": "REAL_AGENT=1 vitest run --config tests/release/vitest.config.ts"
  },
  "wireit": {
    "dev:mac": {
      "dependencies": [
        "./packages/protocol:dev",
        "./packages/sdk:dev",
        "./packages/server:dev:mac",
        "./packages/client:dev:mac"
      ]
    },
    "dev:ios": {
      "dependencies": [
        "./packages/protocol:dev",
        "./packages/sdk:dev",
        "./packages/server:dev:mac",
        "./packages/client:dev:ios"
      ]
    },
    "dev:all": {
      "dependencies": [
        "./packages/protocol:dev",
        "./packages/sdk:dev",
        "./packages/server:dev:mac",
        "./packages/client:dev:mac",
        "./packages/client:dev:ios"
      ]
    }
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "wireit": "^0.14.0"
  }
}
