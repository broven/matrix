{
  "name": "matrix",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev": "pnpm -r --parallel dev",
    "dev:mac": "wireit",
    "dev:ios": "wireit",
    "dev:all": "wireit",
    "open": "sh -c 'set -a; [ -f .env.local ] && . ./.env.local; set +a; open \"$(portless get matrix)?serverUrl=$(portless get api.matrix)&token=${MATRIX_TOKEN}&autoConnect=1\"'",
    "smoke:mac-automation": "bash scripts/smoke-mac-automation.sh",
    "test:e2e:mac": "sh -c 'set -a; [ -f ./.env.test.local ] && . ./.env.test.local; set +a; ENV_FILE=.env.test.local exec pnpm run test:e2e:mac:wireit'",
    "test:e2e:mac:wireit": "wireit",
    "test:e2e:mac:real-agent": "REAL_AGENT=1 pnpm test:e2e:mac"
  },
  "wireit": {
    "dev:mac": {
      "dependencies": [
        "./packages/protocol:dev",
        "./packages/sdk:dev",
        "./packages/server:dev:mac",
        "./packages/client:dev:mac"
      ]
    },
    "dev:ios": {
      "dependencies": [
        "./packages/protocol:dev",
        "./packages/sdk:dev",
        "./packages/server:dev:mac",
        "./packages/client:dev:ios"
      ]
    },
    "dev:all": {
      "dependencies": [
        "./packages/protocol:dev",
        "./packages/sdk:dev",
        "./packages/server:dev:mac",
        "./packages/client:dev:mac",
        "./packages/client:dev:ios"
      ]
    },
    "test:e2e:mac:wireit": {
      "command": "vitest run --config tests/e2e/mac/vitest.config.ts",
      "dependencies": [
        "dev:mac"
      ]
    }
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "vitest": "^3.0.0",
    "wireit": "^0.14.0"
  }
}
