{
  "name": "@matrix/sdk",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "wireit",
    "test": "vitest run"
  },
  "wireit": {
    "dev": {
      "command": "tsc --watch --preserveWatchOutput",
      "service": true,
      "dependencies": [
        "../protocol:dev"
      ]
    }
  },
  "dependencies": {
    "@matrix/protocol": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
