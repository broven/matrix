{
  "name": "@matrix/client",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wireit",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run && node --test test/**/*.test.mjs",
    "test:e2e": "playwright test",
    "tauri": "tauri",
    "tauri:dev": "sh -c 'set -a; [ -f ../../.env.local ] && . ../../.env.local; set +a; exec tauri dev --config \"{\\\"build\\\":{\\\"devUrl\\\":\\\"http://127.0.0.1:${CLIENT_PORT:-5173}\\\"}}\"'",
    "tauri:build": "tauri build",
    "dev:mac": "wireit"
  },
  "wireit": {
    "dev": {
      "command": "sh -c 'set -a; [ -f ../../.env.local ] && . ../../.env.local; set +a; exec vite'",
      "service": true,
      "dependencies": [
        "../protocol:dev",
        "../sdk:dev"
      ]
    },
    "dev:mac": {
      "command": "sh -c 'set -a; [ -f ../../.env.local ] && . ../../.env.local; set +a; SKIP_SIDECAR=true SIDECAR_PORT=$MATRIX_PORT exec tauri dev --config \"{\\\"build\\\":{\\\"devUrl\\\":\\\"http://127.0.0.1:${CLIENT_PORT:-5173}\\\"}}\"'",
      "service": true,
      "dependencies": [
        "dev",
        "../server:dev:mac"
      ]
    }
  },
  "dependencies": {
    "@matrix/protocol": "workspace:*",
    "@matrix/sdk": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/plugin-barcode-scanner": "~2",
    "@tauri-apps/plugin-http": "~2",
    "@tauri-apps/plugin-store": "~2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/api": "~2.10.1",
    "@tauri-apps/cli": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
