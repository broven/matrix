{
  "name": "@matrix/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "bun --watch --env-file=../../.env --env-file=../../.env.local src/index.ts",
    "dev:mac": "wireit",
    "start": "bun --env-file=../../.env --env-file=../../.env.local src/index.ts",
    "test": "bun test"
  },
  "wireit": {
    "dev:mac": {
      "command": "bun --watch --env-file=../../.env --env-file=../../.env.local src/index.ts -- --local true --db-path ./data/dev.db",
      "service": true,
      "dependencies": [
        "../protocol:dev"
      ]
    }
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.1.0",
    "@matrix/protocol": "workspace:*",
    "@types/qrcode-terminal": "^0.12.2",
    "hono": "^4.7.0",
    "nanoid": "^5.1.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}
